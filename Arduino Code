#include <ESP32Servo.h>

Servo s1, s2, s3, s4;

// GPIO pins
int pin1 = 13;
int pin2 = 12;
int pin3 = 14;
int pin4 = 27;

// Current angles
int a1 = 100, a2 = 90, a3 = 90, a4 = 130;

// Speed: 1° every 200 ms → 5°/sec
int stepDelay = 200;

// ----------- PRINT ANGLES -----------
void printAngles() {
  Serial.print("S1: "); Serial.print(a1);
  Serial.print(" | S2: "); Serial.print(a2);
  Serial.print(" | S3: "); Serial.print(a3);
  Serial.print(" | S4: "); Serial.println(a4);
}

// ----------- MOVE ONE SERVO SEQUENTIALLY -----------
void moveServoSequential(Servo &servo, int &current, int target) {
  while (current != target) {
    if (current < target) current++;
    else current--;

    servo.write(current);
    printAngles();
    delay(stepDelay);
  }
}

// ----------- MOVE TO TARGET POSITION -----------
void moveToTarget(int t1, int t2, int t3, int t4) {
  Serial.println("Moving to next position...");

  if (a2 != t2) moveServoSequential(s2, a2, t2);
  if (a3 != t3) moveServoSequential(s3, a3, t3);
  if (a1 != t1) moveServoSequential(s1, a1, t1);
  if (a4 != t4) moveServoSequential(s4, a4, t4);

  Serial.println("✅ Position reached\n");
}

// ----------- SETUP -----------
void setup() {
  Serial.begin(115200);

  s1.attach(pin1);
  s2.attach(pin2);
  s3.attach(pin3);
  s4.attach(pin4);

  // Home position
  s1.write(a1);
  s2.write(a2);
  s3.write(a3);
  s4.write(a4);

  Serial.println("System Started...");
  delay(2000);
}

// ----------- LOOP -----------
void loop() {
  // Move sequence
  moveToTarget(90, 90, 90, 130);
  delay(500);

  moveToTarget(60, 90, 90, 172);
  delay(500);

  moveToTarget(105, 90, 90, 172);
  delay(500);

  moveToTarget(105, 70, 90, 172);
  delay(500);

  moveToTarget(105, 110, 90, 172);
  delay(500);

  moveToTarget(105, 70, 90, 172);
  delay(500);

  moveToTarget(60, 70, 90, 130);
  delay(500);

  moveToTarget(90, 90, 90, 130); // back to home
  delay(1000);
}
